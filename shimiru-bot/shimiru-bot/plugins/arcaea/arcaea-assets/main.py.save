import requests
from bs4 import BeautifulSoup
import os
import re
import time

URL = "https://wiki.arcaea.cn/%E6%9B%B2%E7%9B%AE%E5%88%97%E8%A1%A8"
BASE = "https://wiki.arcaea.cn"

headers = {
    "User-Agent": "Mozilla/5.0"
}

session = requests.Session()
session.headers.update(headers)

print("downloading page...")
r = session.get(URL)
r.raise_for_status()

soup = BeautifulSoup(r.text, "html.parser")

tables = soup.select("table.wikitable.sortable")

os.makedirs("covers", exist_ok=True)

count = 0

for table in tables:
    for tr in table.find_all("tr"):

        tds = tr.find_all("td")
        if len(tds) < 3:
            continue

        # 歌名
        name = tds[2].get_text(strip=True)

        # 曲绘
        link = tds[1].find("a", class_="mw-file-description")
        if not link:
            continue

        href = link.get("href", "")

        m = re.search(r"Songs_(.*?)\.jpg", href)
        if not m:
            continue

        resource = m.group(1)
        filename = f"Songs_{resource}.jpg"
        filepath = f"covers/{filename}"

        if os.path.exists(filepath):
            continue

        # 直接访问 File 页面
        file_url = BASE + href

        print("fetching", filename)

        try:
            file_page = session.get(file_url)
            file_soup = BeautifulSoup(file_page.text, "html.parser")

            full = file_soup.find("div", class_="fullImageLink")

            if not full:
                continue

            img_url = BASE + full.find("a")["href"]

            img = session.get(img_url)

            with open(filepath, "wb") as f:
                f.write(img.content)

            count += 1

        except Exception as e:
            print("failed", filename, e)

        time.sleep(0.5)

print("downloaded", count, "images")
